# Copy this file to .env.local and fill in your Supabase project values.
# Found in your Supabase dashboard under Project Settings -> API.
# These are PUBLIC (safe to expose in a frontend); Row-Level Security protects your data.
#
# If these are left unset, the app runs in offline DEMO MODE with bundled sample data.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Net votes a pending data point needs to become "verified" (default 3).
VITE_VERIFY_THRESHOLD=3
